{
  "expo": {
    "name": "Cha-Ching",
    "slug": "chaching",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#3F8E5C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chaching.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Cha-Ching uses the camera to scan VietQR payment codes.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely unlock your wallet."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3F8E5C"
      },
      "package": "com.chaching.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
